#
# Example .env file
#

# === Application ===

#SPRING_PROFILE=
PORT=8080

# === Java Built-in Session ===

#JSESSION_COOKIE_DOMAIN=
#JSESSION_COOKIE_SAME_SITE=
#JSESSION_COOKIE_SECURE=
#JSESSION_COOKIE_HTTP_ONLY=

# === Spring JDBC Session ===

#SPRING_SESSION_CLEANUP_CRON=

# === Security ===

ACTUATOR_USERNAME=actuator
ACTUATOR_PASSWORD=123

# === Spring Boot Admin ===

# Could fallback to RENDER_EXTERNAL_URL
SERVICE_BASE_URL=http://localhost:8080
# Could fallback to RENDER_EXTERNAL_URL
MANAGEMENT_BASE_URL=http://localhost:8080

ADMIN_MONITOR_URL=http://localhost:8081
ADMIN_MONITOR_USERNAME=admin
ADMIN_MONITOR_PASSWORD=123

# === Database ===

DB_JDBC_URL=jdbc:postgresql://localhost:5432/electric?user=postgres&password=password

# === Datasource ===

#HIKARI_MINIMUM_IDLE=
#HIKARI_IDLE_TIMEOUT=
#HIKARI_KEEPALIVE_TIME=
#HIKARI_CONNECTION_TIMEOUT=

# === Liquibase ===

LIQUIBASE_COMMAND_CHANGELOG_FILE=src/main/resources/db/changelog/changelog-root.yaml

# === Mailing ===

MAIL_HOST=sandbox.smtp.mailtrap.io
MAIL_PORT=2525
#MAIL_USERNAME=
#MAIL_PASSWORD=
MAIL_FROM_EMAIL_NO_REPLY=from@example.com

# === Electric ===

ELECTRIC_URL=http://localhost:4000
ELECTRIC_SECRET=password

# === CORS ===

CORS_ALLOWED_ORIGINS=http://localhost:3000

# === Logging ===

#SPRING_SECURITY_LOG_LEVEL=
#SPRING_SESSION_LOG_LEVEL
#HIBERNATE_SQL_LOG_LEVEL=
#HIKARI_LOG_LEVEL=

# = = = = =
